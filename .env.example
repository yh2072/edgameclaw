# EdGameClaw — Environment Configuration
# Copy this file to .env and fill in your values

# ── Required: AI API ────────────────────────────────────────────────────────
# Your OpenAI-compatible API key
# Get one from: https://openrouter.ai (supports 200+ models, pay-per-use)
# Or use: OpenAI, Anthropic, SiliconFlow, Gemini, etc.
API_KEY=sk-your-api-key-here

# ── Optional: AI Model & Provider ─────────────────────────────────────────
# Default model (any OpenAI-compatible model name)
MODEL=google/gemini-3-flash-preview

# API base URL (OpenRouter recommended — free credits for new accounts)
API_BASE_URL=https://openrouter.ai/api/v1

# ── Optional: Server ────────────────────────────────────────────────────────
# Port to listen on (default: 8000)
# PORT=8000

# Host to bind to. Use 0.0.0.0 to allow LAN access, 127.0.0.1 for localhost only
# BIND_HOST=127.0.0.1

# ── Optional: Node engine state server ──────────────────────────────────────
# Only change if you run the Node engine on a different port
# ENGINE_STATE_URL=http://127.0.0.1:3100

# Auto-start bundled edgameclaw/node when port is free (default: 1). Set 0 if you run node yourself.
# EDGAMECLAW_ENGINE_STATE_AUTO=1
